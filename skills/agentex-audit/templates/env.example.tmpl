# .env.example
#
# Copy to `.env` and fill in real values. `.env` is gitignored;
# `.env.example` is committed and should contain NO real secrets.
#
# Every variable the application reads MUST appear here with a
# descriptive comment. Missing-env-var bugs are one of the top
# sources of agent flail — a complete .env.example eliminates them.

# --- Required ---

# Database connection URL.
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/app_dev

# Third-party API key for <service>. Get one at <url>.
# Without this, <feature> will fail at startup.
THIRD_PARTY_API_KEY=

# --- Optional ---

# Log level. One of: debug, info, warning, error. Default: info.
LOG_LEVEL=info

# Base URL for end-to-end tests. Override in CI/devcontainer.
# Default: http://localhost:<port>
E2E_BASE_URL=http://localhost:5173

# Port the server binds to. Default: <default-port>.
PORT=8000

# --- Development-only ---

# Enable auto-reload on file changes. Default: false in production.
RELOAD=true

# Skip expensive startup checks in local dev. NEVER set in production.
SKIP_HEALTH_CHECKS=false
