  # --- Doc length guardrails ---
  # These keep AGENTS.md and CLAUDE.md below the 200-line threshold
  # recommended by the Claude Code docs. Context-window discipline
  # starts with not letting onboarding docs bloat.
  - repo: local
    hooks:
      - id: claude-md-length
        name: CLAUDE.md length check (≤200 lines)
        entry: bash -c 'if [ -f CLAUDE.md ] && [ "$(wc -l < CLAUDE.md)" -gt 200 ]; then echo "CLAUDE.md exceeds 200 lines"; exit 1; fi'
        language: system
        pass_filenames: false
      - id: agents-md-length
        name: AGENTS.md length check (≤250 lines)
        entry: bash -c 'if [ -f AGENTS.md ] && [ "$(wc -l < AGENTS.md)" -gt 250 ]; then echo "AGENTS.md exceeds 250 lines"; exit 1; fi'
        language: system
        pass_filenames: false
